generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ──────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OtpToken {
  id         String   @id @default(cuid())
  email      String
  code       String
  type       String   @default("login") // login | signup | reset
  attempts   Int      @default(0)
  used       Boolean  @default(false)
  expires    DateTime
  createdAt  DateTime @default(now())

  @@index([email, type])
  @@index([expires])
}

// ─── Users ─────────────────────────────────────

enum PlanTier {
  BASIC
  STARTER
  PRO
  ULTRA
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  hashedPassword  String?
  plan            PlanTier  @default(BASIC)
  isOforoInternal Boolean   @default(false)
  stripeCustomerId String?  @unique
  stripeSubId     String?
  stripePriceId   String?
  aiCreditsUsed   Int       @default(0)
  aiCreditsLimit  Int       @default(10)
  onboardingDone  Boolean   @default(false)
  referralCode    String?   @unique
  referredBy      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  assessments     Assessment[]
  careerPlans     CareerPlan[]
  learningPaths   LearningPath[]
  resumes         Resume[]
  portfolios      Portfolio[]
  jobApplications JobApplication[]
  coachSettings   CoachSettings?
  autoApplyConfig AutoApplyConfig?
  autoApplyRuns   AutoApplyRun[]
  agentActivities AgentActivity[]
  auditLogs       AuditLog[]
  careerTwin      CareerTwin?
  subscriptions   Subscription[]
  creditPurchases CreditPurchase[]
  couponsRedeemed CouponRedemption[]
  referralsGiven  Referral[]       @relation("ReferrerReferrals")
  referralsUsed   Referral[]       @relation("ReferredReferrals")
  emailLogs       EmailLog[]
  newsletterSub   NewsletterSubscriber?
  tickets         SupportTicket[]

  @@index([email])
  @@index([referralCode])
}

// ─── Subscriptions & Billing ─────────────────────

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubId        String             @unique
  stripePriceId      String
  stripeCustomerId   String
  status             SubscriptionStatus @default(ACTIVE)
  plan               PlanTier
  interval           String             @default("month") // month | year
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([userId])
  @@index([stripeSubId])
}

model CreditPurchase {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credits          Int
  amountPaid       Int      // cents
  stripePaymentId  String?
  createdAt        DateTime @default(now())

  @@index([userId])
}

// ─── Coupon System ──────────────────────────────

model Coupon {
  id           String             @id @default(cuid())
  code         String             @unique
  plan         PlanTier
  maxUses      Int                @default(1)
  usedCount    Int                @default(0)
  durationDays Int?               // null = permanent upgrade
  expiresAt    DateTime?
  isActive     Boolean            @default(true)
  createdBy    String             // admin userId
  createdAt    DateTime           @default(now())
  redemptions  CouponRedemption[]

  @@index([code])
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([couponId, userId])
  @@index([userId])
}

// ─── Referral System ─────────────────────────────

enum ReferralStatus {
  PENDING
  ACTIVATED
  REWARDED
  EXPIRED
}

model Referral {
  id          String         @id @default(cuid())
  referrerId  String
  referrer    User           @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId  String
  referred    User           @relation("ReferredReferrals", fields: [referredId], references: [id], onDelete: Cascade)
  status      ReferralStatus @default(PENDING)
  rewardType  String         @default("pro_month") // pro_month | credits_100
  createdAt   DateTime       @default(now())

  @@unique([referrerId, referredId])
  @@index([referrerId])
}

// ─── Email System ────────────────────────────────

enum EmailType {
  WELCOME
  OTP_LOGIN
  OTP_SIGNUP
  EMAIL_VERIFIED
  ONBOARDING_DAY2
  ONBOARDING_DAY5
  ONBOARDING_DAY7
  UPGRADE_NUDGE
  CREDIT_LOW
  WEEKLY_DIGEST
  REFERRAL_INVITE
  PASSWORD_RESET
  SUBSCRIPTION_CONFIRM
  SUBSCRIPTION_CANCELED
  PAYMENT_FAILED
  ACCOUNT_ACTIVITY
}

model EmailLog {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      EmailType
  subject   String
  to        String
  status    String    @default("sent") // sent | failed | bounced
  messageId String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([type])
}

// ─── Newsletter ──────────────────────────────────

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  active    Boolean  @default(true)
  source    String   @default("website") // website | signup | blog
  createdAt DateTime @default(now())

  @@index([email])
}

// ─── Blog / Content Marketing ────────────────────

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model BlogPost {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  excerpt     String
  content     String     @db.Text
  coverImage  String?
  author      String     @default("NXTED AI Team")
  category    String     @default("career-tips")
  tags        Json       @default("[]")
  status      PostStatus @default(DRAFT)
  views       Int        @default(0)
  readTime    Int        @default(5)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([slug])
  @@index([status])
  @@index([category])
}

// ─── Career Twin (persistent user model) ───────

model CareerTwin {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillSnapshot    Json
  interests        Json
  workStyle        Json?
  targetRoles      Json
  marketReadiness  Float    @default(0)
  hireProb         Float    @default(0)
  lastUpdated      DateTime @updatedAt
  createdAt        DateTime @default(now())
}

// ─── Assessments ───────────────────────────────

enum AssessmentStatus {
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

model Assessment {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetRole  String
  status      AssessmentStatus @default(IN_PROGRESS)
  questions   Json
  answers     Json?
  skillScores Json?
  aiAnalysis  Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
}

// ─── Career Plans ──────────────────────────────

model CareerPlan {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetRole  String
  timeline    Json
  milestones  Json
  projects    Json
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// ─── Learning Paths ────────────────────────────

model LearningPath {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetRole   String
  modules      Json
  progress     Json
  adaptive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

// ─── Resumes ───────────────────────────────────

model Resume {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  template    String   @default("modern")
  content     Json
  targetJob   String?
  atsScore    Float?
  pdfUrl      String?
  isFinalized Boolean  @default(false)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// ─── Portfolios ────────────────────────────────

model Portfolio {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug        String   @unique
  title       String
  bio         String?
  projects    Json
  skills      Json
  theme       String   @default("dark")
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([slug])
}

// ─── Job Applications ──────────────────────────

enum ApplicationStatus {
  QUEUED
  APPLIED
  EMAILED
  VIEWED
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

model JobApplication {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobTitle        String
  company         String
  location        String?
  salaryRange     String?
  matchScore      Float?
  status          ApplicationStatus @default(QUEUED)
  appliedAt       DateTime?
  source          String?
  auditTrail      Json?
  resumeId        String?
  coverLetter     String?           @db.Text
  notes           String?           @db.Text
  jobUrl          String?
  autoApplyRunId  String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId])
}

// ─── AI Coach Settings ─────────────────────────

model CoachSettings {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String  @default("Cortex")
  personality String  @default("friendly")
  avatarUrl   String?
  enabled     Boolean @default(true)
}

// ─── Auto Apply System ──────────────────────────

model AutoApplyConfig {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled          Boolean   @default(false)
  resumeId         String?
  targetRoles      Json      @default("[]")
  targetLocations  Json      @default("[]")
  minMatchScore    Int       @default(60)
  maxAppliesPerRun Int       @default(5)
  excludeCompanies Json      @default("[]")
  excludeKeywords  Json      @default("[]")
  scheduleTime     String?
  preferRemote     Boolean   @default(false)
  lastRunAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model AutoApplyRun {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      String    @default("running")
  jobsFound   Int       @default(0)
  jobsApplied Int       @default(0)
  jobsSkipped Int       @default(0)
  creditsUsed Int       @default(0)
  summary     String?   @db.Text
  details     Json?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([startedAt])
}

model AgentActivity {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent       String   // scout | archer | forge | atlas | sage | sentinel
  action      String   // discovered_jobs | sent_application | optimized_resume | etc
  summary     String
  details     Json?
  creditsUsed Int      @default(0)
  runId       String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([agent])
  @@index([createdAt])
}

// ─── Audit Logs ────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ─── Analytics / Page Views ────────────────────

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  country   String?
  city      String?
  device    String?  // desktop | mobile | tablet
  browser   String?
  os        String?
  sessionId String?
  userId    String?
  duration  Int?     // seconds spent on page
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
  @@index([country])
  @@index([sessionId])
}

// ─── Support Tickets ──────────────────────────

model SupportTicket {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     String
  category    String          @default("general") // general | bug | feature | billing | account
  priority    String          @default("medium")  // low | medium | high | urgent
  status      String          @default("open")    // open | in_progress | resolved | closed
  messages    TicketMessage[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId])
  @@index([status])
}

model TicketMessage {
  id          String        @id @default(cuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId    String
  senderRole  String        @default("user") // user | admin
  content     String        @db.Text
  createdAt   DateTime      @default(now())

  @@index([ticketId])
}

// ─── Changelog ────────────────────────────────

model Changelog {
  id               String    @id @default(cuid())
  title            String
  content          String    @db.Text
  category         String    @default("feature") // feature | improvement | bugfix | announcement
  version          String?
  isPublic         Boolean   @default(true)
  sendToNewsletter Boolean   @default(false)
  publishedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ─── Newsletter Campaigns ─────────────────────

model NewsletterCampaign {
  id        String    @id @default(cuid())
  subject   String
  content   String    @db.Text
  status    String    @default("draft") // draft | sending | sent | failed
  sentCount Int       @default(0)
  sentAt    DateTime?
  createdAt DateTime  @default(now())
}

// ─── Marketing Dashboard ────────────────────────

model MarketingPhase {
  id          String   @id @default(cuid())
  name        String   // e.g. "Phase 1: India + US"
  description String   @db.Text
  status      String   @default("not_started") // not_started, in_progress, completed
  progress    Int      @default(0) // 0-100
  startDate   DateTime?
  endDate     DateTime?
  tasks       MarketingTask[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MarketingTask {
  id          String   @id @default(cuid())
  phaseId     String
  phase       MarketingPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  title       String
  description String?  @db.Text
  category    String   @default("seo") // seo, content, youtube, social, partnerships, technical
  status      String   @default("pending") // pending, in_progress, completed, blocked
  priority    String   @default("medium") // low, medium, high, critical
  assignee    String?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([phaseId])
  @@index([status])
}

model MarketingKPI {
  id        String   @id @default(cuid())
  name      String   // e.g. "Organic Traffic", "Blog Articles", "Paying Subscribers"
  category  String   @default("traffic") // traffic, content, revenue, social
  target    Int      // target value
  current   Int      @default(0) // current value
  unit      String   @default("count") // count, currency, percentage
  period    String   @default("monthly") // daily, weekly, monthly, quarterly
  month     Int      // 1-12
  year      Int      // 2026
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, month, year])
  @@index([category])
}

model ContentCalendar {
  id            String   @id @default(cuid())
  title         String
  targetKeyword String?
  keywordDifficulty Int?  @default(0)
  category      String   @default("blog") // blog, landing_page, comparison, video, social
  status        String   @default("planned") // planned, writing, review, published, scheduled
  scheduledDate DateTime?
  publishedDate DateTime?
  publishedUrl  String?
  author        String?
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([category])
}
