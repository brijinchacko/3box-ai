generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ──────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users ─────────────────────────────────────

enum PlanTier {
  BASIC
  PRO
  ULTRA
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  hashedPassword  String?
  plan            PlanTier  @default(BASIC)
  isOforoInternal Boolean   @default(false)
  stripeCustomerId String?
  stripeSubId     String?
  aiCreditsUsed   Int       @default(0)
  aiCreditsLimit  Int       @default(50)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  assessments     Assessment[]
  careerPlans     CareerPlan[]
  learningPaths   LearningPath[]
  resumes         Resume[]
  portfolios      Portfolio[]
  jobApplications JobApplication[]
  coachSettings   CoachSettings?
  auditLogs       AuditLog[]
  careerTwin      CareerTwin?

  @@index([email])
}

// ─── Career Twin (persistent user model) ───────

model CareerTwin {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillSnapshot    Json     // { skill: score } map
  interests        Json     // array of strings
  workStyle        Json?    // personality/work preference data
  targetRoles      Json     // array of role objects
  marketReadiness  Float    @default(0) // 0-100
  hireProb         Float    @default(0) // probability of hire 0-1
  lastUpdated      DateTime @updatedAt
  createdAt        DateTime @default(now())
}

// ─── Assessments ───────────────────────────────

enum AssessmentStatus {
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

model Assessment {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetRole  String
  status      AssessmentStatus @default(IN_PROGRESS)
  questions   Json             // array of question objects
  answers     Json?            // array of answer objects
  skillScores Json?            // { skill: percent } map
  aiAnalysis  Json?            // AI gap analysis
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
}

// ─── Career Plans ──────────────────────────────

model CareerPlan {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetRole  String
  timeline    Json     // milestones array
  milestones  Json     // detailed milestone objects
  projects    Json     // proof-of-work projects
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// ─── Learning Paths ────────────────────────────

model LearningPath {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetRole   String
  modules      Json     // array of learning module objects
  progress     Json     // { moduleId: progress } map
  adaptive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

// ─── Resumes ───────────────────────────────────

model Resume {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  template    String   @default("modern")
  content     Json     // structured resume data
  targetJob   String?
  atsScore    Float?
  pdfUrl      String?
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// ─── Portfolios ────────────────────────────────

model Portfolio {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug        String   @unique
  title       String
  bio         String?
  projects    Json     // array of project objects
  skills      Json     // displayed skills
  theme       String   @default("dark")
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([slug])
}

// ─── Job Applications ──────────────────────────

enum ApplicationStatus {
  QUEUED
  APPLIED
  VIEWED
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

model JobApplication {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobTitle      String
  company       String
  location      String?
  salaryRange   String?
  matchScore    Float?
  status        ApplicationStatus @default(QUEUED)
  appliedAt     DateTime?
  source        String?           // "manual" | "auto"
  auditTrail    Json?             // automation audit log
  resumeId      String?
  coverLetter   String?           @db.Text
  notes         String?           @db.Text
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([userId])
}

// ─── AI Coach Settings ─────────────────────────

model CoachSettings {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String  @default("Nova")
  personality String  @default("friendly") // friendly | professional | motivational | technical
  avatarUrl   String?
  enabled     Boolean @default(true)
}

// ─── Audit Logs ────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
