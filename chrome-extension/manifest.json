{
  "manifest_version": 3,
  "name": "3BOX AI — Auto Apply",
  "version": "1.0.0",
  "description": "Automatically apply to jobs on LinkedIn, Indeed, Naukri, Glassdoor, Workday, and iCIMS with your 3BOX AI profile.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://www.indeed.com/*",
    "https://indeed.com/*",
    "https://www.naukri.com/*",
    "https://naukri.com/*",
    "https://www.glassdoor.com/*",
    "https://glassdoor.com/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.icims.com/*",
    "https://3box.ai/*",
    "https://localhost:3002/*"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://linkedin.com/jobs/*"
      ],
      "js": ["dist/content-linkedin.js"],
      "css": ["dist/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.indeed.com/*",
        "https://indeed.com/*"
      ],
      "js": ["dist/content-indeed.js"],
      "css": ["dist/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.naukri.com/*",
        "https://naukri.com/*"
      ],
      "js": ["dist/content-naukri.js"],
      "css": ["dist/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.glassdoor.com/*",
        "https://glassdoor.com/*"
      ],
      "js": ["dist/content-glassdoor.js"],
      "css": ["dist/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.myworkdayjobs.com/*"
      ],
      "js": ["dist/content-workday.js"],
      "css": ["dist/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.icims.com/*"
      ],
      "js": ["dist/content-icims.js"],
      "css": ["dist/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
