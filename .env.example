# ─── Database ───────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/nxted_ai"

# ─── NextAuth ───────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-strong-secret-here"

# ─── Google OAuth ───────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── OpenRouter AI ──────────────────────────────
OPENROUTER_API_KEY=""
OPENROUTER_DEFAULT_MODEL="meta-llama/llama-3.1-8b-instruct:free"
OPENROUTER_PREMIUM_MODEL="anthropic/claude-sonnet-4"

# ─── Stripe ─────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_PRO_YEARLY_PRICE_ID=""
STRIPE_ULTRA_MONTHLY_PRICE_ID=""
STRIPE_ULTRA_YEARLY_PRICE_ID=""

# ─── Redis ──────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── S3 Storage ─────────────────────────────────
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# ─── OFORO Internal ─────────────────────────────
OFORO_INTERNAL_DOMAINS="oforo.ai,oforoai.com"
OFORO_ADMIN_EMAILS="admin@oforo.ai"

# ─── App Config ─────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="NXTED AI"
NODE_ENV="development"
