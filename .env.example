# ─── Database ───────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/3box_ai"

# ─── NextAuth ───────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-strong-secret-here"

# ─── Google OAuth ───────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── OpenRouter AI ──────────────────────────────
OPENROUTER_API_KEY=""
OPENROUTER_DEFAULT_MODEL="meta-llama/llama-3.1-8b-instruct:free"
OPENROUTER_PREMIUM_MODEL="anthropic/claude-sonnet-4"

# ─── Stripe ─────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Starter plan
STRIPE_STARTER_MONTHLY_PRICE_ID=""
STRIPE_STARTER_YEARLY_PRICE_ID=""

# Pro plan
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_PRO_YEARLY_PRICE_ID=""

# Ultra plan
STRIPE_ULTRA_MONTHLY_PRICE_ID=""
STRIPE_ULTRA_YEARLY_PRICE_ID=""

# Credit packs
STRIPE_CREDITS_100_PRICE_ID=""
STRIPE_CREDITS_500_PRICE_ID=""
STRIPE_CREDITS_1000_PRICE_ID=""

# ─── Email (Resend) ────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="3BOX AI <noreply@3box.ai>"

# ─── Redis ──────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── S3 Storage ─────────────────────────────────
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# ─── OFORO Internal ─────────────────────────────
OFORO_INTERNAL_DOMAINS="oforo.ai,oforoai.com"
OFORO_ADMIN_EMAILS="admin@oforo.ai"

# ─── RapidAPI (JSearch Job Search) ─────────────
RAPIDAPI_KEY=your_rapidapi_key_here

# ─── App Config ─────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="3BOX AI"
NODE_ENV="development"
